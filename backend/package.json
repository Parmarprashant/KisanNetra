{
  "name": "krishi-raksha-api",
  "version": "1.0.0",
  "description": "Krishi Raksha — AI-powered crop disease early detection backend",
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:treatments": "ts-node-dev --transpile-only src/scripts/seedTreatments.ts",
    "ingest:kb": "ts-node-dev --transpile-only src/scripts/ingestKnowledgeBase.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@google/genai": "^2.12.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@sendgrid/mail": "^8.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.9",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nanoid": "^3.3.16",
    "pdfkit": "^0.19.1",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.1",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.10",
    "ioredis-mock": "^8.13.1",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
