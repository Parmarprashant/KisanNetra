# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
# CORS allowlist (Phase 15) — comma-separated origins. Falls back to APP_URL
# when unset. e.g. https://app.krishiraksha.in,https://admin.krishiraksha.in
CORS_ORIGINS=

# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/krishi_raksha

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (used from Phase 2) ─────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-256-bit-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ══════════════════════════════════════════════════════════════════
# The variables below are consumed by later phases. They are OPTIONAL
# for Phase 1 (Foundation) and can be left blank until their phase.
# ══════════════════════════════════════════════════════════════════

# ─── GEMINI API (Phase 3 vision + Phase 6 embeddings) ────────────
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
CONFIDENCE_THRESHOLD=0.65

# ─── GROQ API (Phase 6 — RAG chatbot LLM) ────────────────────────
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ─── AWS S3 / MinIO (Phase 4 — required for scan storage) ────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=krishi-raksha-images
AWS_REGION=ap-south-1
# Set S3_ENDPOINT for MinIO / self-hosted; leave blank for real AWS S3.
S3_ENDPOINT=http://localhost:9000

# ─── Qdrant (Phase 6 — RAG vector store) ─────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=krishi_knowledge_base
# QDRANT_API_KEY=            # set for Qdrant Cloud; omit for local Docker
EMBED_DIMENSION=3072        # gemini-embedding-001 output size

# ─── Embeddings fallback (Phase 6, optional) ─────────────────────
# HUGGINGFACE_API_KEY=

# ─── Notifications (Phase 7 — all optional; each channel is env-gated) ──
# Email (SendGrid). Both are required together for email delivery; without
# them the email channel and password-reset emails are skipped (logged).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@krishiraksha.in
# SMS (Twilio). All three required together for SMS delivery.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# Web Push (VAPID). Generate a keypair with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@krishiraksha.in

# ─── ML Bridge (optional, Phase 3) ───────────────────────────────
# ML_SERVICE_URL=http://localhost:8000
# ML_INTERNAL_KEY=

# ─── Monitoring ──────────────────────────────────────────────────
# SENTRY_DSN=
